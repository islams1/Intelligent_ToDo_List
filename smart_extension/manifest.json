{
  "manifest_version": 3,
  "name": "Smart Meeting Assistant",
  "version": "1.0",
  "description": "AI Assistant for managing meetings via Localhost",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Assistant"
  },
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ]
}